  "keyFeatures": [
    "Massively parallel linking using Intel TBB for multi-core scalability",
    "Drop-in replacement for GNU ld and ld.lld with full compatibility",
    "Support for 20+ CPU architectures including x86-64, ARM64, RISC-V, PowerPC, and more",
    "Deterministic, bit-for-bit reproducible output regardless of thread scheduling",
    "Identical Code Folding (ICF) for output size optimization",
    "Section garbage collection (--gc-sections) with parallel mark-sweep",
    "Separate debug file generation (--separate-debug-file) for faster startup",
    "Link-Time Optimization (LTO) support for GCC and Clang",
    "mold -run wrapper to intercept ld calls without modifying build scripts",
    "GDB index generation (--gdb-index) for faster debugging sessions"
  ],
  "publicApiSurface": [
    "mold [options] file...",
    "-fuse-ld=mold (Clang/GCC 12.1+)",
    "-B/usr/libexec/mold (GCC before 12.1)",
    "mold -run <command> [args]",
    "--gc-sections",
    "--icf=[safe|all|none]",
    "--separate-debug-file",
    "--gdb-index",
    "--build-id=[md5|sha1|sha256|fast|uuid|none]",
    "--compress-debug-sections=[zlib|zstd|none]",
    "--version-script=<file>",
    "--dynamic-list=<file>",
    "--wrap=<symbol>",
    "--thread-count=<n>",
    "MOLD_JOBS environment variable",
    "MOLD_DEBUG environment variable",
    "MOLD_REPRO environment variable"
  ]
